generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MANAGER
  MEMBER
}

enum WorkItemStatus {
  BACKLOG
  ASSIGNED
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TimeExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActivityAction {
  ITEM_CREATED
  ITEM_UPDATED

  MEMBERS_ASSIGNED
  MEMBERS_REASSIGNED
  MEMBERS_REMOVED

  WORK_STARTED
  SUBMITTED_FOR_REVIEW
  REVIEW_ACCEPTED
  SENT_BACK
  ITEM_CANCELLED
  ITEM_REOPENED
  STATUS_CHANGED

  TIME_EXTENSION_REQUESTED
  TIME_EXTENSION_APPROVED
  TIME_EXTENSION_REJECTED

  ATTACHMENT_ADDED
  ATTACHMENT_REPLACED
  ATTACHMENT_REMOVED

  RETURNED_TO_BACKLOG
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  passwordHash String
  role         Role   @default(MEMBER)

  createdWorkItems WorkItem[] @relation("WorkItemCreatedBy")

  assignments     WorkItemAssignment[] @relation("AssignmentMember")
  assignmentsMade WorkItemAssignment[] @relation("AssignmentAssignedBy")

  activities Activity[] @relation("ActivityActor")

  extensionRequests TimeExtensionRequest[] @relation("ExtensionRequestedBy")
  extensionReviews  TimeExtensionRequest[] @relation("ExtensionReviewedBy")

  attachmentsUploaded Attachment[] @relation("AttachmentUploadedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@map("users")
}

model WorkItem {
  id          String         @id @default(uuid())
  title       String
  description String
  priority    Priority       @default(MEDIUM)
  category    String
  dueDate     DateTime
  status      WorkItemStatus @default(BACKLOG)

  createdById String
  createdBy   User   @relation("WorkItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  assignments           WorkItemAssignment[]
  activities            Activity[]
  timeExtensionRequests TimeExtensionRequest[]
  attachment            Attachment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([createdById])
  @@index([status, dueDate])
  @@map("work_items")
}

model WorkItemAssignment {
  workItemId String
  memberId   String

  assignedById String
  assignedAt   DateTime @default(now())

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  member User @relation("AssignmentMember", fields: [memberId], references: [id], onDelete: Cascade)

  assignedBy User @relation("AssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)

  @@id([workItemId, memberId])
  @@index([memberId])
  @@index([assignedById])
  @@map("work_item_assignments")
}

model Activity {
  id         String          @id @default(uuid())
  action     ActivityAction
  fromStatus WorkItemStatus?
  toStatus   WorkItemStatus?
  details    Json?

  workItemId String
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([workItemId, createdAt])
  @@index([actorId])
  @@map("activities")
}

model TimeExtensionRequest {
  id              String              @id @default(uuid())
  currentDueDate  DateTime
  proposedDueDate DateTime
  reason          String
  status          TimeExtensionStatus @default(PENDING)
  reviewNote      String?
  reviewedAt      DateTime?

  workItemId String
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  requestedById String
  requestedBy   User   @relation("ExtensionRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)

  reviewedById String?
  reviewedBy   User?   @relation("ExtensionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workItemId, status])
  @@index([requestedById])
  @@index([reviewedById])
  @@map("time_extension_requests")
}

model Attachment {
  id           String @id @default(uuid())
  originalName String
  storedName   String
  mimeType     String
  sizeBytes    Int
  storagePath  String

  workItemId String   @unique
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([uploadedById])
  @@map("attachments")
}
