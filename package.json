{
   "name": "taskflow",
   "version": "1.0.0",
   "private": true,
   "workspaces": [
      "apps/*"
   ],
   "scripts": {
      "dev:web": "npm run dev --workspace=web",
      "dev:api": "npm run start:dev --workspace=api",
      "lint": "npm run lint --workspaces --if-present",
      "build": "npm run build --workspaces --if-present",
      "test": "npm run test --workspaces --if-present",
      "verify": "npm run lint && npm run test && npm run build"
   },
   "repository": {
      "type": "git",
      "url": "git+https://github.com/rjanahi/taskFlow.git"
   },
   "keywords": [],
   "author": "",
   "license": "ISC",
   "bugs": {
      "url": "https://github.com/rjanahi/taskFlow/issues"
   },
   "homepage": "https://github.com/rjanahi/taskFlow#readme",
   "dependencies": {
      "bcryptjs": "^3.0.3"
   }
}
